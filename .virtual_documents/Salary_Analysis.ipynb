ax.ticklabel_format(style='plain', axis='y')
ax.grid(axis='y',linestyle='--',alpha=1)
 
for i, value in enumerate(city_salary):
    ax.text(i, value, str(round(value, 0)),
            ha='center', va='bottom')

plt.tight_layout()
